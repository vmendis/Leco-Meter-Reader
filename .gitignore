.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Project specific
# Exclude gradlew script as it's specific to local setup
!gradlew
!gradlew.bat

# Exclude gradle wrapper directory as it's specific to local setup
!gradle/wrapper/

# Exclude local.properties file as it contains local paths
!local.properties

# Exclude .gitignore file itself
!.gitignore

# Exclude README.md as it should be version controlled
!README.md

# Exclude documentation files
!Docs/
!plans/
!roo_plan/